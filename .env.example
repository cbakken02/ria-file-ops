PERSISTENCE_BACKEND=sqlite

NEXTAUTH_SECRET=replace-this-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Supabase/Postgres is required only when PERSISTENCE_BACKEND=supabase.
# Local development continues to default to SQLite.
SUPABASE_DB_URL_POOLER=postgresql://user:password@host:6543/postgres
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
APP_ENCRYPTION_KEY=replace-with-a-32-byte-base64-or-64-char-hex-key
