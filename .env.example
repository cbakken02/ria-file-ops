# RIA File Ops environment template
# Copy to .env.local for local development. Never paste real secrets into this file.

# App/auth
# Required for basic local SQLite dev and all deployed environments.
NEXTAUTH_SECRET=replace-this-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth / Drive
# Required only when testing Google sign-in or Google Drive locally.
# Local OAuth redirect URIs:
# - http://localhost:3000/api/auth/callback/google
# - http://localhost:3000/api/storage/google/callback
# Production OAuth redirect URIs:
# - https://ria-file-ops.vercel.app/api/auth/callback/google
# - https://ria-file-ops.vercel.app/api/storage/google/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Persistence backend
# Required everywhere. Use sqlite for normal local development.
# Use supabase only for Vercel or for explicit local integration testing against
# a separate hosted dev/staging Supabase project. Do not point local tests at
# the production Supabase database.
PERSISTENCE_BACKEND=sqlite

# SQLite
# Optional local overrides. Defaults are under ./data and are gitignored.
RIA_FIRM_DOCUMENT_DB_PATH=
RIA_FIRM_DOCUMENT_DB_DIR=
RIA_PREVIEW_ANALYSIS_CACHE_DIR=

# Supabase Postgres
# Required only when PERSISTENCE_BACKEND=supabase.
# Prefer SUPABASE_DB_URL_POOLER in Vercel/serverless. Keep production and
# dev/staging Supabase projects separate.
SUPABASE_DB_URL_POOLER=postgresql://user:password@host:6543/postgres
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres

# Supabase API metadata
# Currently documented for project identification/future server-only tooling.
# The app's runtime persistence path uses Postgres directly via pg.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Encryption
# Required when PERSISTENCE_BACKEND=supabase because storage connection tokens
# are encrypted before they are written to Postgres.
APP_ENCRYPTION_KEY=replace-with-a-32-byte-base64-or-64-char-hex-key

# OpenAI / AI parser
# Optional for local development. Required only when testing AI-backed parser
# paths or deployed AI parser behavior.
AI_PRIMARY_PARSER=false
AI_PRIMARY_ACCOUNT_STATEMENT_ONLY=true
OPENAI_API_KEY=your-openai-api-key
AI_PRIMARY_PARSER_MODEL=gpt-4.1-mini
AI_PRIMARY_PARSER_TIMEOUT_MS=30000
# Optional OpenAI-compatible endpoint override:
# AI_PRIMARY_PARSER_API_URL=https://api.openai.com/v1/chat/completions

# Data Intelligence assistant
# Optional. If model/key/url are omitted, Data Intelligence can fall back to the
# extraction-layer AI settings or deterministic retrieval depending on config.
DATA_INTELLIGENCE_AI_ENABLED=false
DATA_INTELLIGENCE_MODEL=
DATA_INTELLIGENCE_API_KEY=
# Optional OpenAI-compatible endpoint override:
# DATA_INTELLIGENCE_API_URL=https://api.openai.com/v1/chat/completions

# Data Intelligence V2
# V2 is disabled by default. Enable only in explicit dev/staging/production
# rollout steps. Use postgres reveal storage for production sensitive reveal.
DATA_INTELLIGENCE_V2_ENABLED=false
DATA_INTELLIGENCE_V2_CHAT_API_ENABLED=false
DATA_INTELLIGENCE_V2_REVEAL_API_ENABLED=false
DATA_INTELLIGENCE_V2_UI_ENABLED=false
DATA_INTELLIGENCE_V2_ALLOW_SENSITIVE_REVEAL=false
DATA_INTELLIGENCE_V2_REVEAL_EXPIRES_MS=600000
DATA_INTELLIGENCE_V2_REVEAL_STORE_BACKEND=auto
DATA_INTELLIGENCE_V2_AUDIT_BACKEND=auto
DATA_INTELLIGENCE_V2_DEV_MOCK_ENABLED=false
DATA_INTELLIGENCE_V2_PREVIEW_QA_ENABLED=false
DATA_INTELLIGENCE_V2_PREVIEW_QA_SECRET=

# Data Intelligence V2 OpenAI Responses adapter
DATA_INTELLIGENCE_V2_OPENAI_ENABLED=false
DATA_INTELLIGENCE_V2_OPENAI_API_KEY=your-openai-api-key
DATA_INTELLIGENCE_V2_MODEL=
DATA_INTELLIGENCE_V2_OPENAI_BASE_URL=https://api.openai.com/v1
DATA_INTELLIGENCE_V2_OPENAI_TIMEOUT_MS=30000
DATA_INTELLIGENCE_V2_OPENAI_MAX_OUTPUT_TOKENS=

# Data Intelligence V2 evals
# These are for local fake-data evals only and are disabled in production.
DATA_INTELLIGENCE_V2_EVAL_OPENAI_ENABLED=false
DATA_INTELLIGENCE_V2_EVAL_ALLOW_NETWORK=false

# Vercel/deployment
# Vercel sets VERCEL automatically. Set NEXTAUTH_URL to the canonical production
# URL in Vercel Production: https://ria-file-ops.vercel.app
